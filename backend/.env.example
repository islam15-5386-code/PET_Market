APP_NAME="Pet Marketplace"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-laravel-api.onrender.com
APP_FRONTEND_URL=https://your-frontend.vercel.app

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=your-db-host
DB_PORT=5432
DB_DATABASE=pet_marketplace
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

CACHE_STORE=file
FILESYSTEM_DISK=cloudinary
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@petmarketplace.com"
MAIL_FROM_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# ── Social OAuth (FR-01) ──────────────────────────────────────────────────────
# Register apps at:
#   Google:   https://console.cloud.google.com/apis/credentials
#   Facebook: https://developers.facebook.com/apps/

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-laravel-api.onrender.com/api/auth/social/google/callback

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/api/auth/social/facebook/callback

FRONTEND_URL=https://your-frontend.vercel.app
AI_SERVICE_URL=https://your-ai-service.onrender.com
AI_TIMEOUT_SECONDS=20
AI_DESCRIPTION_TIMEOUT=30
AI_CHATBOT_TIMEOUT=30
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# PetCare AI Assistant provider.
# Keep these server-side only. Do not add them to frontend NEXT_PUBLIC_* env vars.
AI_PROVIDER=gemini
AI_CHAT_TIMEOUT_SECONDS=20
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudinary (for uploads/files in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
