APP_NAME=pet-ai-service
APP_ENV=production
PORT=8001

DATABASE_URL=postgresql://user:password@your-neon-or-supabase-host:5432/pet_marketplace
BACKEND_API_URL=https://your-laravel-api.onrender.com
APP_FRONTEND_URL=https://your-frontend.vercel.app
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-laravel-api.onrender.com

AI_PROVIDER=gemini
AI_TIMEOUT_SECONDS=30
MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
